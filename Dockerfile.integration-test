# Dockerfile.integration-test
FROM ubuntu:24.04

# Configuração de repositórios multi-arch (mesmo que o Dockerfile principal)
RUN dpkg --add-architecture arm64 && \
    rm /etc/apt/sources.list.d/ubuntu.sources && \
    echo "Types: deb\n\
URIs: http://archive.ubuntu.com/ubuntu/\n\
Suites: noble noble-updates noble-backports\n\
Components: main universe restricted multiverse\n\
Signed-By: /usr/share/keyrings/ubuntu-archive-keyring.gpg\n\
Architectures: amd64 i386" > /etc/apt/sources.list.d/amd64.sources && \
    echo "Types: deb\n\
URIs: http://ports.ubuntu.com/ubuntu-ports/\n\
Suites: noble noble-updates noble-backports\n\
Components: main universe restricted multiverse\n\
Signed-By: /usr/share/keyrings/ubuntu-archive-keyring.gpg\n\
Architectures: arm64" > /etc/apt/sources.list.d/arm64.sources

RUN apt-get update && apt-get install -y \
    python3 python3-numpy qemu-user-static \
    build-essential cmake git crossbuild-essential-arm64 \
    curl libcurl4-openssl-dev:arm64

# Install Rust for the builder
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable && \
    . "$HOME/.cargo/env" && \
    rustup target add aarch64-unknown-linux-gnu

ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /app
COPY . .

# Build the app aarch64
RUN rm -rf build && mkdir -p build && cd build && \
    cmake -DCMAKE_SYSTEM_NAME=Linux \
          -DCMAKE_SYSTEM_PROCESSOR=aarch64 \
          -DCMAKE_C_COMPILER=aarch64-linux-gnu-gcc \
          -DCMAKE_CXX_COMPILER=aarch64-linux-gnu-g++ \
          .. && \
    make -j$(nproc)

# Entrypoint will be the test script
CMD ["/bin/bash", "/app/scripts/test-integration.sh"]
